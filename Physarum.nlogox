<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[;; =========================================================================
;; Physarum polycephalum — Snell's Law Refraction Simulation
;; Author: Gemini (eurAIka mode)
;; Date: 2026-05-04
;; Framework: Jones (2010) Agent-Based Model
;; =========================================================================

turtles-own [
  speed          ; current movement speed (patch-lengths per tick)
]

patches-own [
  chemo          ; chemoattractant concentration (real, >= 0)
  medium-speed   ; zone-dependent agent speed multiplier
  is-boundary    ; boolean — true for patches at pycor = 0
  is-source      ; boolean
  is-food        ; boolean
  visited        ; boolean — has any turtle ever been here?
]

globals [
  ;; Parameters (set via interface sliders or setup-params)
  ; v1                    ; agent speed in Zone 1 (lower)
  ; v2                    ; agent speed in Zone 2 (upper)
  ; num-agents            ; number of turtles
  ; deposit-amount        ; chemo deposited per turtle per tick
  ; diffusion-rate        ; fraction spread to Moore neighbors
  ; decay-rate            ; fraction of chemo lost per tick
  sensor-distance       ; SD
  sensor-angle          ; SA
  ; chemo-threshold       ; percentile cutoff for tube extraction
  
  ;; World Layout
  source-x source-y
  food-x food-y
  source-radius food-radius
  ; max-ticks
  
  ;; Output tracking
  ; condition             ; "A" (Fast-to-Slow), "B" (Slow-to-Fast), "C" (Control)
  first-contact-tick
  x-cross
  x-cross-history       ; list of [tick x-cross]
  x-cross-final
  starting-seed          ; RENAMED from random-seed to avoid primitive conflict
]

;; -------------------------------------------------------------------------
;; Setup Procedures
;; -------------------------------------------------------------------------

to setup
  clear-all
  set-parameters
  setup-rng             
  setup-patches
  setup-turtles
  
  set first-contact-tick -1
  set x-cross-history []
  set x-cross-final -9999
  reset-ticks
end

to setup-rng
  ;; Use initial-seed if set, otherwise generate new seed
  if starting-seed = 0 [ set starting-seed new-seed ]
  random-seed starting-seed
end

to set-parameters
  ;; Defaulting to Condition A: Fast-to-Slow (Refraction right)
  ; set v1 1.0            ; Zone 1 (Fast)
  ; set v2 0.5            ; Zone 2 (Slow)
  ; set condition "A"
  
  ; set num-agents 400
  ; set deposit-amount 5.0
  ; set diffusion-rate 0.3
  ; set decay-rate 0.05
  set sensor-distance 9
  set sensor-angle 45
  ; set chemo-threshold 90
  
  set source-x -75 set source-y -75
  set food-x 75 set food-y 75
  set source-radius 3
  set food-radius 3
  ; set max-ticks 5000
end

to random-seed-setup
  ;; If not set via external batch, use system time
  if starting-seed = 0 [ set starting-seed new-seed ]
  random-seed starting-seed
end

to setup-patches
  ask patches [
    set chemo 0
    set visited false
    set is-boundary (pycor = 0)

    let speed-lower ifelse-value (condition = "B") [v2] [v1]
    let speed-upper ifelse-value (condition = "B") [v1]
                    [ifelse-value (condition = "C") [v1] [v2]]

    ifelse pycor < 0
      [ set medium-speed speed-lower  set pcolor 26  ]
      [ set medium-speed speed-upper  set pcolor 106 ]

    set is-source (distancexy source-x source-y <= source-radius)
    set is-food   (distancexy food-x food-y     <= food-radius)
    if is-source [ set pcolor yellow ]
    if is-food   [ set pcolor green  ]
    if is-boundary [ set pcolor pcolor + 2 ]
  ]
end

to setup-turtles
  create-turtles num-agents [
    ;; Start within source radius
    setxy (source-x + random-float (2 * source-radius) - source-radius)
          (source-y + random-float (2 * source-radius) - source-radius)
    set heading random 360
    set color orange
    set size 1
    set speed [medium-speed] of patch-here
  ]
end

;; -------------------------------------------------------------------------
;; Main Loop
;; -------------------------------------------------------------------------

to go
  ;; Stop conditions
  if ticks >= max-ticks [ finalize stop ]
  
  ;; Optional: auto-stop after stabilization post-contact
  ; if (first-contact-tick > 0) and (ticks - first-contact-tick > 3500) [
  ;   finalize stop
  ; ]

  ask turtles [ move-turtle ]
  update-environment
  
  ;; Track emergence
  if (first-contact-tick = -1) and (any? turtles-on patches with [is-food]) [
    set first-contact-tick ticks
  ]
  
  if first-contact-tick > 0 [
    set x-cross measure-x-cross
    set x-cross-history lput (list ticks x-cross) x-cross-history
  ]
  
  tick
end

to move-turtle
  ;; 1. Update local speed
  set speed [medium-speed] of patch-here
  
  ;; 2. Sense
  let left-val   chemo-at (heading - sensor-angle) sensor-distance
  let center-val chemo-at heading sensor-distance
  let right-val  chemo-at (heading + sensor-angle) sensor-distance
  
  ;; 3. Turn logic
  if (left-val > right-val) and (left-val > center-val) [ left sensor-angle ]
  if (right-val > left-val) and (right-val > center-val) [ right sensor-angle ]
  
  ;; 4. Move with reflective boundaries
  let new-x xcor + (speed * sin heading)
  let new-y ycor + (speed * cos heading)

  ;; Reflect off vertical walls (left/right)
  if new-x > max-pxcor or new-x < min-pxcor [
    set heading (- heading)          ;; reflect in Y axis
    set new-x xcor + (speed * sin heading)
  ]

  ;; Reflect off horizontal walls (top/bottom)
  if new-y > max-pycor or new-y < min-pycor [
    set heading (180 - heading)      ;; reflect in X axis
    set new-y ycor + (speed * cos heading)
  ]

  setxy new-x new-y
  
  ;; 5. Deposit
  set chemo chemo + deposit-amount
end

to-report chemo-at [dir dist]
  let target-patch patch-at-heading-and-distance dir dist
  if target-patch = nobody [ report 0 ]
  report [chemo] of target-patch
end

to update-environment
  ;; Constantly replenish chemo at food and source patches
  ;; This is the Jones (2010) food-as-attractor mechanism
  ask patches with [is-food]   [ set chemo 1000 ]
  ask patches with [is-source] [ set chemo 200 ]
  
  diffuse chemo diffusion-rate
  ask patches [
    set chemo chemo * (1 - decay-rate)
    if chemo < 0.001 [ set chemo 0 ]
    if any? turtles-here [ set visited true ]
    
    ;; Visual representation of chemo trail
    if not is-source and not is-food [
      if chemo > 0 [
        set pcolor scale-color orange chemo 0.1 20
      ]
    ]
  ]
end

;; -------------------------------------------------------------------------
;; Metrics & Finalization
;; -------------------------------------------------------------------------

to-report measure-x-cross
  let threshold-val percentile-chemo chemo-threshold
  let candidates patches with [is-boundary and chemo >= threshold-val]
  
  if not any? candidates [ report -9999 ]
  
  ;; Find the centroid of the main flux tube at the boundary
  let winner max-one-of candidates [chemo]
  report [pxcor] of winner
end

to-report percentile-chemo [pct]
  let values sort [chemo] of patches with [
    visited and chemo > 0 and not is-food and not is-source
  ]
  if length values = 0 [ report 0 ]
  let idx round ((pct / 100) * (length values - 1))
  report item idx values
end

to finalize
  set x-cross-final x-cross
  ;; export-results would be called here in headless/batch mode
  print (word "Run Complete. Final X-Cross: " x-cross-final " at tick " ticks)
end]]></code>
